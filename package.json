{
  "name": "beacon-health",
  "version": "0.1.0",
  "description": "Clean-room TypeScript CLI for synthetic non-clinical appointment readiness beacons.",
  "type": "module",
  "bin": {
    "beacon-health": "./dist/src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && node dist/src/index.js",
    "demo": "npm start",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "validate": "npm run build && node dist/scripts/validate.js"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
